{
  "name": "Delta Lake Dev",
  "image": "mcr.microsoft.com/devcontainers/java:21",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.10"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "scalameta.metals",
        "scala-lang.scala"
      ],
      "settings": {
        "metals.sbtScript": "sbt",
        "metals.javaHome": "/usr/lib/jvm/msopenjdk-current"
      }
    }
  },
  "postCreateCommand": "echo 'Dev container ready. Run: sbt compile'",
  "remoteEnv": {
    "SBT_OPTS": "-Xmx4G"
  }
}
